{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2024", "ESNext", "DOM", "DOM.Iterable", "esnext.disposable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "declaration": false,
    "composite": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "jsx": "react-jsx"
  },
  "include": ["packages/**/src/**/*.ts", "packages/**/src/**/*.tsx"],
  "exclude": [
    "packages/domain/pricing-engine/**",
    "packages/domain/recovery-cascade-intelligence/**",
    "packages/service/recovery-cascade-intelligence-orchestrator/**",
    "packages/shared/type-level/src/stress-fabric-atlas.ts",
    "packages/shared/type-level/src/stress-template-fusion-lab.ts"
  ]
}
